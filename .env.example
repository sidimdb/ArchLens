# ============================================================
#  ArchLens — environment variables
# ============================================================
#
# Copy this file to ".env" at the project root, then paste real
# values in. ".env" is git-ignored; ".env.example" is committed
# so contributors know what's needed.
#
#   cp .env.example .env
#   # then edit .env
# ============================================================


# ----- Anthropic / Claude API -----
# Required by both archlens-statik (AI rule explanations and
# recommendations) and archlens-runtime (the vision-based verify
# loop that compares before/after screenshots).
#
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional override of the Claude model used everywhere.
# Default: claude-sonnet-4-5-20250929  (Sonnet tier — best balance
# of quality, cost, and Turkish-language fluency for our use case).
# Examples of other valid values:
#   claude-sonnet-4-5-20250929
#   claude-haiku-4-5-20251014
# Leave commented out to use the default.
# CLAUDE_MODEL=claude-sonnet-4-5-20250929


# ----- Static analyzer backend (optional) -----
# Port the Express server listens on. Defaults to 3001 if unset.
# PORT=3001
