{
  "name": "@archlens/statik-backend",
  "version": "0.2.0",
  "private": true,
  "description": "ArchLens — static architectural analyzer for React Native projects (backend).",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
